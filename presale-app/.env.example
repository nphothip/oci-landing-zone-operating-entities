# ---- LLM (โหมดพิมพ์อธิบาย free text) — ใส่ key อย่างน้อย 1 ตัวถ้าจะใช้โหมด AI ----
# เลือก provider: gemini | openai | none (ว่าง = auto จาก key ที่มี)
LLM_PROVIDER=
# Gemini — ใช้อย่างใดอย่างหนึ่ง:
#   GEMINI_API_KEY=              # Google AI Studio API key
#   GOOGLE_APPLICATION_CREDENTIALS=   # path ไปยัง service account JSON (Vertex AI)
#   GEMINI_PROJECT_ID=           # จำเป็นเมื่อใช้ service account (หรืออ่านจาก JSON)
#   GEMINI_LOCATION=us-central1  # region ของ Vertex AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=   # สำหรับ proxy/Azure-compatible endpoint

# ---- Pricing (AIS Cloud, Oracle Alloy Thailand — THB) ----
PRICE_TTL_HOURS=24
# PRICE_API_URL=https://calculator.g-ais.co.th/api/skus

# ---- AI narrative (เอกสารออกแบบ) — timeout ต่อ 1 คำขอ (โมเดล reasoning อาจใช้ ~60-90s) ----
# LLM_JSON_TIMEOUT_MS=120000

# ---- Generator (ปกติไม่ต้องตั้ง — Docker ตั้งให้แล้ว) ----
# REPO_ROOT=            # path ไปยัง checkout ของ oci-landing-zone-operating-entities
# JSONNET_BIN=          # path ไปยัง jsonnet binary (ค่าเริ่มต้น: ~/go/bin/jsonnet หรือจาก PATH)
# PYTHON_BIN=           # ค่าเริ่มต้น: python (Windows) / python3 (Linux)
# GENERATOR_TIMEOUT_MS=60000
